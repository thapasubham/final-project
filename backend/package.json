{
  "name": "fonts",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "tsc && --env-file=.env node dist/src/index.js",
    "dev": "tsx --watch --env-file=.env src/index.ts",
    "typeorm": "node --env-file=.env --loader ts-node/esm ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run -d ./src/data-source.ts",
    "migration:gen": "npm run typeorm -- migration:generate -d ./src/data-source.ts ./src/migrations/time",
    "migration:create": "npm run typeorm -- migration:create ./src/migrations/time"
  },
  "keywords": [],
  "author": "Subham Thapa",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.1",
    "pg": "^8.16.2",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.25"
  }
}
