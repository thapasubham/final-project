{
  "name": "fonts",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "tsc && --env-file=.env node dist/src/index.js",
    "insert-font": "tsx --env-file=.env src/insert.ts",
    "compress": "tsx src/compress.ts",
        "stripe:listen": "stripe listen --forward-to localhost:3000/api/payment/webhook",

    "dev": "tsx --watch --env-file=.env src/index.ts",
    "local": "tsx --watch --env-file=.env.local src/index.ts",
    "lint": "eslint",
    "typeorm": "node --env-file=.env.local --loader ts-node/esm ./node_modules/typeorm/cli.js",
    "test": "c8  mocha src/tests/**/*.test.ts ",
    "migration:run": "npm run typeorm -- migration:run -d ./src/data-source.ts",
    "migration:gen": "npm run typeorm -- migration:generate -d ./src/data-source.ts src/migrations/time",
   "migration:show": "npm run  typeorm -- migration:show -d ./src/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create ./src/migrations/time"
  },

  "keywords": [],
  "author": "Subham Thapa",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/bcrypt": "^5.0.2",
    "@types/chai": "^5.2.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^1.4.13",
    "@types/mysql": "^2.15.27",
    "@types/node": "^24.0.3",
    "@types/sinon": "^17.0.4",
    "c8": "^10.1.3",
    "chai": "^5.2.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "mocha": "^11.2.2",
    "sinon": "^20.0.0",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  },
  "dependencies": {
    "@apollo/server": "^4.12.0",
    "bcrypt": "^6.0.0",
    "chalk": "^5.4.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-jwt": "^8.5.1",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "multer": "^2.0.1",
    "mysql": "^2.18.1",
    "pg": "^8.16.2",
    "reflect-metadata": "^0.2.2",
    "stripe": "^20.0.0",
    "ts-node": "^10.9.2",
    "ttf2woff2": "^8.0.0",
    "typeorm": "^0.3.25"
  }
}